# -*- mode: snippet -*-
# name: Systemd Unit
# key: tpl
# condition: (<= (current-column) 3)
# --
$0# /usr/lib/systemd/system/vvv.service
[Unit]
Description=vvv
After=network-online.target

[Service]
User=vip
ExecStart=/home/vip/.notes/x.utils/sync-notes-html.sh

[Install]
WantedBy=multi-user.target
